es\">\r\n                                    <a href=\"/EmissorNacional/Notas/Visualizar/Index/31367021221601471000125000000001231926030535075594\"\r\n                                       data-toggle=\"tooltip\" data-placement=\"top\" title=\"Visualizar\">\r\n                                        <img src=\"/EmissorNacional/img/tb-visualizar.svg\" />\r\n                                    </a>\r\n                                </td>\r\n                            </tr>\r\n                            <tr data-chave=\"UzRRTk13ZThaVVFzcXkzTkFQRVl5YXlnT1lQYW90eGpCNWt1Mlp1aE1FMmxSNUlyNFEvbkRZNHlxNE9KK0hFbzY1MTlFSjlKMkljPQ2\">\r\n                                <td class=\"td-data\" data-label=\"Geração\">\r\n                                    04/03/2026\r\n                                </td>\r\n                                <td class=\"td-texto-grande\" data-label=\"Emitida para\">\r\n                                    <div>\r\n<img data-toggle=\"tooltip\" title=\"Tomador\" src=\"/EmissorNacional/img/tb-tomador.svg\" />\r\n                                                <span class=\"cnpj\">05650104000165</span>\r\n                                                -\r\nISOINSTITUTO DE SAUDE OCUPACIONAL LTDA                                    </div>\r\n                                </td>\r\n                                <td class=\"td-valor\">\r\n                                    1.216,00\r\n                                </td>\r\n                                <td class=\"td-opcoes\">\r\n                                    <a href=\"/EmissorNacional/Notas/Visualizar/Index/31367021221601471000125000000001231826030534963948\"\r\n                                       data-toggle=\"tooltip\" data-placement=\"top\" title=\"Visualizar\">\r\n                                        <img src=\"/EmissorNacional/img/tb-visualizar.svg\" />\r\n                                    </a>\r\n                                </td>\r\n                            </tr>\r\n                            <tr data-chave=\"UzRRTk13ZThaVVFzcXkzTkFQRVl5YXlnT1lQYW90eGpCNWt1Mlp1aE1FMnlnc1pFNjYrUW9KUGFhM1VjVVp3T1VqWTJ6cjF6ckk4PQ2\">\r\n                                <td class=\"td-data\" data-label=\"Geração\">\r\n                                    04/03/2026\r\n                                </td>\r\n                                <td class=\"td-texto-grande\" data-label=\"Emitida para\">\r\n                                    <div>\r\n<img data-toggle=\"tooltip\" title=\"Tomador\" src=\"/EmissorNacional/img/tb-tomador.svg\" />\r\n                                                <span class=\"cnpj\">00600573000156</span>\r\n                                                -\r\nCONSTRUTORA BELOI LTDA                                    </div>\r\n                                </td>\r\n                                <td class=\"td-valor\">\r\n                                    2.980,74\r\n                                </td>\r\n                                <td class=\"td-opcoes\">\r\n                                    <a href=\"/EmissorNacional/Notas/Visualizar/Index/31367021221601471000125000000001231726030534937250\"\r\n                                       data-toggle=\"tooltip\" data-placement=\"top\" title=\"Visualizar\">\r\n                                        <img src=\"/EmissorNacional/img/tb-visualizar.svg\" />\r\n                                    </a>\r\n                                </td>\r\n                            </tr>\r\n                    </tbody>\r\n                </table>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"wgtRascunhos\" class=\"widget\">\r\n        <div class=\"cabecalho\"><img class=\"icone\" src=\"/EmissorNacional/img/rascunho-azul-20.svg\" />Rascunhos</div>\r\n        <div class=\"jdash-body table\">\r\n                <p class=\"dashboard-sem-registros\">\r\n                    A emissão de uma nova NFS-e é dividida em 4 passos: Pessoas, Serviço, Valores e Revisão/Emissão.\r\n                    Durante cada emissão, ao passar para o próximo passo, as informações preenchidas até o momento serão salvas\r\n                    e listadas aqui. Todos os rascunhos poderão ser acessados a qualquer momento até que a NFS-e seja emitida.\r\n                </p>\r\n        </div>\r\n    </div>\r\n\r\n</div>\r\n\r\n    </div>\r\n\r\n    <footer>\r\n        <div class=\"parceiros\">\r\n            <div class=\"container\">\r\n                <div class=\"row\">\r\n                    <div class=\"col-md-offset-1 col-md-2\">\r\n                        <a href=\"http://idg.receita.fazenda.gov.br/\" target=\"_blank\">\r\n                            <img src=\"/EmissorNacional/img/logo-rfb.png\" class=\"logo\" alt=\"Receita Federal do Brasil\">\r\n                        </a>\r\n                    </div>\r\n                    <div class=\"col-md-2\">\r\n                        <a href=\"http://www.sebrae.com.br/\" target=\"_blank\">\r\n                            <img src=\"/EmissorNacional/img/logo-sebrae.png\" class=\"logo\" alt=\"Sebrae\">\r\n                        </a>\r\n                    </div>\r\n                    <div class=\"col-md-2\">\r\n                        <a href=\"http://www.cnm.org.br/\" target=\"_blank\">\r\n                            <img src=\"/EmissorNacional/img/logo-cnm.png\" class=\"logo\" alt=\"Confederação Nacional dos Municípios\">\r\n                        </a>\r\n                    </div>\r\n                    <div class=\"col-md-2\">\r\n                        <a href=\"http://www.abrasf.org.br/\" target=\"_blank\">\r\n                            <img src=\"/EmissorNacional/img/logo-abrasf.png\" class=\"logo\" alt=\"Associação Brasileira das Secretarias de Finanças das Capitais\">\r\n                        </a>\r\n                    </div>\r\n                    <div class=\"col-md-2\">\r\n                        <a href=\"http://portal.siscomex.gov.br/legislacao/orgaos/secretaria-de-comercio-exterior-secex\" target=\"_blank\">\r\n                            <img src=\"/EmissorNacional/img/logo-secex.png\" class=\"logo\" alt=\"Secretaria de Comércio Exterior\" />\r\n                        </a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class=\"info\">\r\n            <div class=\"container\">\r\n                <div class=\"row\">\r\n                    <div class=\"col-md-4 logo\">\r\n                        <img src=\"/EmissorNacional/img/logo-nfse-branca-sm.svg\" class=\"logo-branca\" alt=\"NFS-e\" />\r\n                    </div>\r\n                    <div class=\"col-md-8 versao\">\r\n                        Portal de Gestão NFS-e - Contribuinte | Versão 1.4.0.27\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </footer>\r\n\r\n    <div id=\"modalLoading\" class=\"modalBgLoading\" style=\"display:none;\">\r\n        <div class=\"loading\">\r\n            <div class=\"spinner\">\r\n                <div class=\"bounce1\"></div>\r\n                <div class=\"bounce2\"></div>\r\n                <div class=\"bounce3\"></div>\r\n            </div>\r\n            <div class=\"texto\">Por favor, aguarde...</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div id=\"modalPessoa\" class=\"modal fade bs-example-modal-lg\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"myLargeModalLabel\">\r\n        <div class=\"modal-dialog modal-lg\" role=\"document\">\r\n            <div class=\"modal-content\">\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n</body>\r\n</html>\r\n"
