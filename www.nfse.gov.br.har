ontainer-body {\n    padding-top: 10px;\n    padding-bottom: 40px;\n}\n\n.container {\n    width: 95%;\n}\n\n@media (min-width: 1800px) {\n    .container {\n        width: 1730px;\n    }\n}\n\na,\na:visited,\na:active,\na:focus {\n    text-decoration: none;\n    color: #79B182;\n}\n\n    a:hover {\n        text-decoration: none;\n        color: #344389;\n    }\n\nhr {\n    margin-top: 5px;\n    margin-bottom: 5px;\n    border: 0;\n    border-top: 1px solid #E6E6E6;\n}\n\n\n/*DEFINIÇÕES DO RODAPÉ*/\nfooter {\n}\n\n    footer .parceiros {\n        padding: 40px 0;\n        text-align: center;\n        background-color: #f3f3f3;\n    }\n\n        footer .parceiros .logo {\n            height: 50px;\n            margin: 10px 0;\n        }\n\n    footer .info {\n        background-color: #709E77;\n        padding: 10px 0;\n    }\n\n        footer .info .logo {\n            text-align: left;\n        }\n\n        footer .info .versao {\n            text-align: right;\n            padding: 4px 0px;\n            color: #fff;\n            font-size: 12px;\n        }\n\n\n/*MARCA DE AMBIENTE*/\n.pnlMarcadorAmbiente {\n    background-color: #f6c228;\n    color: #344389;\n    text-transform: uppercase;\n    font-size: 11pt;\n    font-weight: 500;\n    text-align: center;\n    padding: 1px 0;\n}\n\n\n/*BREADCRUMBS*/\n.breadcrumbs {\n    font-size: 14px;\n    color: #709e77;\n}\n\n    .breadcrumbs .nome-sistema {\n        color: #344389;\n    }\n\n    .breadcrumbs .separador {\n        padding: 0 5px;\n    }\n\n    .breadcrumbs a {\n        color: #787993;\n    }\n\n        .breadcrumbs a:hover {\n            color: #709e77;\n            text-decoration: none;\n        }\n\n    .breadcrumbs i {\n        padding: 0 5px;\n        color: #ccc;\n    }\n\n\n\n\nh1.titulo {\n    margin: 0;\n    padding-bottom: 10px;\n    font-size: 24px;\n    color: #397FBB;\n}\n\nh1.titulo-sessao {\n    margin: 15px 0 20px;\n    font-size: 22px;\n    color: #67709C;\n    font-weight: normal;\n}\n\n​.comandos-rodape {\n    margin: 30px 0;\n}\n\n.radio-option-block {\n    margin-bottom: 10px;\n}\n\n.main-menu {\n    background-color: #D7DCD9;\n    border-radius: 0;\n    border-color: #D7DCD9;\n    min-width: 250px;\n}\n\n.caret {\n    margin-left: 5px;\n}\n\n.help-usuario h3 {\n    font-size: 24px;\n    line-height: 30px;\n    margin-bottom: 30px;\n    color: #709e77;\n}\n\n.help-usuario p {\n    font-size: 18px;\n    margin-bottom: 20px;\n}\n\n\n\nul.leaders {\n    padding: 0;\n    overflow-x: hidden;\n    list-style: none;\n    /*margin-top: 15px;*/\n}\n\n    ul.leaders li {\n        line-height: 35px;\n    }\n\n        ul.leaders li:before {\n            float: left;\n            width: 0;\n            white-space: nowrap;\n            content: \". . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .\";\n        }\n\n        ul.leaders li.subTitulo {\n            font-weight: bold;\n        }\n\n            ul.leaders li.subTitulo:before {\n                content: \"\";\n            }\n\n    /*ul.leaders li.subItem {\n            margin-left: 20px;\n        }*/\n\n    ul.leaders span:first-child {\n        padding-right: 0.33em;\n        background: #DCECDF;\n    }\n\n    ul.leaders span + span {\n        float: right;\n        padding-left: 0.33em;\n        background: #DCECDF;\n    }\n\n    ul.leaders .vazio {\n        padding-right: 30px;\n    }\n\n\n\n.emissao-titulo {\n    margin: 15px 0;\n}\n\n.emissao-conteudo {\n    background-color: #F1F1F1;\n    padding: 15px 0;\n    margin-bottom: 15px;\n    border-top: solid 1px #DCDCDC;\n}\n\n.dl-horizontal {\n    margin: 0;\n}\n\n    .dl-horizontal dt {\n        width: 40%;\n        padding: 5px 15px 5px 0;\n        font-weight: normal;\n        color: #777;\n        white-space: normal;\n    }\n\n    .dl-horizontal dd {\n        padding: 5px 15px 5px 0;\n        margin-left: 40%;\n        font-style: italic;\n        color: #000;\n    }\n\n\n.datepicker-dropdown {\n    z-index: 2000 !important;\n}\n\n.float-left {\n    float: left;\n}\n\n.jconfirm .jconfirm-cell {\n    vertical-align: top !important;\n}\n\n.jconfirm .jconfirm-box {\n    border-radius: 0 !important;\n}\n\n    .jconfirm .jconfirm-box div.jconfirm-title-c {\n        color: #709E77 !important;\n        font-size: 18px !important;\n        border-bottom: solid 2px #8bb091;\n    }\n\n    .jconfirm .jconfirm-box div.jconfirm-content-pane {\n        margin: 20px 0 !important;\n        text-align: center;\n    }\n\n    .jconfirm .jconfirm-box .jconfirm-buttons {\n        float: none;\n        width: 100% !important;\n        text-align: center !important;\n    }\n\n        .jconfirm .jconfirm-box .jconfirm-buttons button {\n            font-size: 15px !important;\n            font-weight: normal !important;\n            padding: 6px 20px !important;\n        }\n\n            .jconfirm .jconfirm-box .jconfirm-buttons button.btn-blue {\n                background-color: #344389 !important;\n            }\n\n                .jconfirm .jconfirm-box .jconfirm-buttons button.btn-blue:hover {\n                    background-color: #1d2c71 !important;\n                }\n\n            .jconfirm .jconfirm-box .jconfirm-buttons button.btn-default {\n                background: #c6d8c9 !important;\n                color: #444444 !important;\n            }\n\n                .jconfirm .jconfirm-box .jconfirm-buttons button.btn-default:hover {\n                    background: #aecdb4 !important;\n                    color: #444444 !important;\n                }\n\n\n.spinner {\n    margin: 40px auto 0;\n    width: 70px;\n    text-align: center;\n}\n\n    .spinner > div {\n        width: 18px;\n        height: 18px;\n        background-color: #fff;\n        border-radius: 100%;\n        display: inline-block;\n        -webkit-animation: sk-bouncedelay 1.4s infinite ease-in-out both;\n        animation: sk-bouncedelay 1.4s infinite ease-in-out both;\n    }\n\n    .spinner .bounce1 {\n        -webkit-animation-delay: -0.32s;\n        animation-delay: -0.32s;\n    }\n\n    .spinner .bounce2 {\n        -webkit-animation-delay: -0.16s;\n        animation-delay: -0.16s;\n    }\n\n@-webkit-keyframes sk-bouncedelay {\n    0%, 80%, 100% {\n        -webkit-transform: scale(0);\n    }\n\n    40% {\n        -webkit-transform: scale(1.0);\n    }\n}\n\n@keyframes sk-bouncedelay {\n    0%, 80%, 100% {\n        -webkit-transform: scale(0);\n        transform: scale(0);\n    }\n\n    40% {\n        -webkit-transform: scale(1.0);\n        transform: scale(1.0);\n    }\n}\n\n.color-blue {\n    color: #5971B7;\n}\n\n.color-green {\n    color: #52B961;\n}\n\n.color-red {\n    color: #E27F78;\n}\n\nh2 {\n    margin: 0;\n    font-size: 26px;\n    color: #709E77;\n    padding: 15px 0;\n    position: relative;\n    font-weight: 400;\n}\n\n.pnlCollapse {\n    position: relative;\n    background-color: #f7f7f7;\n    border: 1px solid #e1e1e1;\n    border-width: 1px 0;\n    margin-bottom: 15px;\n}\n\n    .pnlCollapse > h1 {\n        margin: 0;\n        font-size: 20px;\n        color: #709E77;\n        padding: 15px 20px 15px 45px;\n        position: relative;\n        font-weight: 400;\n        text-transform: uppercase;\n    }\n\n        .pnlCollapse > h1:hover {\n            cursor: pointer;\n            background: rgba(225,225,225,1);\n            background: -moz-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n            background: -webkit-gradient(left top, left bottom, color-stop(0%, rgba(225,225,225,1)), color-stop(100%, rgba(247,247,247,1)));\n            background: -webkit-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n            background: -o-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n            background: -ms-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n            background: linear-gradient(to bottom, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n            filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#e1e1e1', endColorstr='#f7f7f7', GradientType=0 );\n        }\n\n        .pnlCollapse > h1 > i {\n            font-size: 24px;\n            position: absolute;\n            left: 20px;\n            top: 14px;\n            -webkit-transition: all 0.2s ease-out;\n            -moz-transition: all 0.2s ease-out;\n            -ms-transition: all 0.2s ease-out;\n            -o-transition: all 0.2s ease-out;\n            transition: all 0.2s ease-out;\n        }\n\n    .pnlCollapse.aberto > h1 > i {\n        -webkit-transform: rotate(90deg);\n        -moz-transform: rotate(90deg);\n        -ms-transform: rotate(90deg);\n        -o-transform: rotate(90deg);\n        transform: rotate(90deg);\n        -webkit-transition: all 0.2s ease-out;\n        -moz-transition: all 0.2s ease-out;\n        -ms-transition: all 0.2s ease-out;\n        -o-transition: all 0.2s ease-out;\n        transition: all 0.2s ease-out;\n    }\n\n    .pnlCollapse.semi-aberto > h1 > i {\n        -webkit-transform: rotate(180deg);\n        -moz-transform: rotate(180deg);\n        -ms-transform: rotate(180deg);\n        -o-transform: rotate(180deg);\n        transform: rotate(180deg);\n        -webkit-transition: all 0.2s ease-out;\n        -moz-transition: all 0.2s ease-out;\n        -ms-transition: all 0.2s ease-out;\n        -o-transition: all 0.2s ease-out;\n        transition: all 0.2s ease-out;\n    }\n\n    .pnlCollapse > h2 {\n        margin: 0;\n        font-size: 20px;\n        color: #709E77;\n        padding: 15px 20px;\n        position: relative;\n        font-weight: 400;\n        text-transform: uppercase;\n    }\n\n    .pnlCollapse .retratil {\n        padding: 0 20px 10px;\n    }\n\n    .pnlCollapse .maisInfo {\n        text-align: center;\n        padding-bottom: 10px;\n    }\n\n        .pnlCollapse .maisInfo > a {\n            color: #709E77;\n            font-size: 14px;\n            text-decoration: none;\n        }\n\n            .pnlCollapse .maisInfo > a:hover {\n                color: #28418C;\n                text-decoration: none;\n            }\n\n\n    .pnlCollapse.emissao-calculos {\n        background-color: #E5F3E7;\n    }\n\n        .pnlCollapse.emissao-calculos > h1:hover {\n            cursor: pointer;\n            background: rgba(225,225,225,1);\n            background: -moz-linear-gradient(top, rgba(193, 220, 196,1) 0%, rgba(229, 243, 231,1) 100%);\n            background: -webkit-gradient(left top, left bottom, color-stop(0%, rgba(193, 220, 196,1)), color-stop(100%, rgba(229, 243, 231,1)));\n            background: -webkit-linear-gradient(top, rgb(193, 220, 196) 0%, rgb(229, 243, 231) 100%);\n            background: -o-linear-gradient(top, rgb(193, 220, 196) 0%, rgb(229, 243, 231) 100%);\n            background: -ms-linear-gradient(top, rgb(193, 220, 196) 0%, rgb(229, 243, 231) 100%);\n            background: linear-gradient(to bottom, rgb(193, 220, 196) 0%, rgb(229, 243, 231) 100%);\n            filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#e1e1e1', endColorstr='#f7f7f7', GradientType=0 );\n        }\n\n        .pnlCollapse.emissao-calculos .emissao-conteudo {\n            background-color: #DCECDF;\n            padding: 15px;\n            border-top: solid 1px #C7E0CB;\n        }\n\n\n\n#pnlDeducoes .opcoes {\n    text-align: center;\n    margin-bottom: 12px;\n}\n\n    #pnlDeducoes .opcoes .btn {\n        min-width: 145px;\n    }\n\n\n.monetario,\n.percentual {\n    text-align: right;\n}\n\n.status1 {\n    color: #1ca31f;\n}\n\n.status2 {\n    color: #e13232;\n}\n\n.status3 {\n    color: #e17a17;\n}\n\n.has-spin i {\n    padding-right: 10px;\n}\n\n.navbar-default {\n    border-width: 0;\n    margin-bottom: 10px;\n    background: rgba(230,228,229,1);\n    background: -moz-linear-gradient(top, rgba(230,228,229,1) 0%, rgba(247,247,247,1) 100%);\n    background: -webkit-gradient(left top, left bottom, color-stop(0%, rgba(230,228,229,1)), color-stop(100%, rgba(247,247,247,1)));\n    background: -webkit-linear-gradient(top, rgba(230,228,229,1) 0%, rgba(247,247,247,1) 100%);\n    background: -o-linear-gradient(top, rgba(230,228,229,1) 0%, rgba(247,247,247,1) 100%);\n    background: -ms-linear-gradient(top, rgba(230,228,229,1) 0%, rgba(247,247,247,1) 100%);\n    background: linear-gradient(to bottom, rgba(230,228,229,1) 0%, rgba(247,247,247,1) 100%);\n    filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#e6e4e5', endColorstr='#f7f7f7', GradientType=0 );\n    /*-webkit-box-shadow: 0px 0px 10px 0px rgba(169, 187, 176,1);\n    -moz-box-shadow: 0px 0px 10px 0px rgba(169, 187, 176,1);\n    box-shadow: 0 0 10px 0 rgb(169, 187, 176);*/\n}\n\n    /*.navbar-default .container {\n        display: block;\n        position: relative;\n    }\n\n        .navbar-default .container::after {\n            content: \"\";\n            background: url(../img/moldura-municipio.png);\n            opacity: 0.5;\n            top: 0;\n            left: 0;\n            bottom: 0;\n            right: 0;\n            position: absolute;\n            z-index: -1;\n        }*/\n\n    /*.navbar-default .container {\n        background-image: url('../img/moldura-municipio.png');\n        background-repeat: no-repeat;\n        background-position: left;\n    }*/\n\n    .navbar-default .divisor {\n        height: 62px;\n        margin: 12px 9px;\n        border-left: 1px solid #d0d0d0;\n    }\n\n    .navbar-default .navbar-nav > li > a,\n    .navbar-default .navbar-nav > li > a:active,\n    .navbar-default .navbar-nav > li > a:visited {\n        color: #709E77;\n        font-size: 26px;\n        padding-top: 20px;\n        padding-bottom: 0;\n        min-height: 77px;\n        margin-top: 6px;\n        transition: 0.2s all ease-in-out;\n    }\n\n        .navbar-default .navbar-nav > .open > a,\n        .navbar-default .navbar-nav > .open > a:hover,\n        .navbar-default .navbar-nav > .open > a:focus,\n        .navbar-default .navbar-nav > li > a:hover {\n            transition: 0.2s all ease-in-out;\n            transform: scale(1.15);\n            color: #709E77;\n            background-color: #D7DCD9;\n        }\n\n    .navbar-default .navbar-nav > li.perfil .dropdown-menu {\n        min-width: 350px;\n        right: -5px;\n    }\n\n        .navbar-default .navbar-nav > li.perfil .dropdown-menu .dropdown-header {\n            white-space: normal;\n        }\n\n/*.navbar-default .navbar-nav > .open > a,\n    .navbar-default .navbar-nav > .open > a:hover,\n    .navbar-default .navbar-nav > .open > a:focus {\n        color: #FFF;\n        background-color: #D7DCD9;\n    }*/\n\n\n.dropdown-menu > li > a {\n    padding: 8px 20px;\n    color: #709E77;\n    letter-spacing: .5px;\n    font-weight: 400;\n    font-size: 16px;\n}\n\n    .dropdown-menu > li > a:hover,\n    .dropdown-menu > li > a:focus {\n        color: #304233;\n        text-decoration: none;\n        background-color: #CAD2CD;\n    }\n\n.dropdown-menu .dropdown-header {\n    font-size: 16px;\n    padding: 10px 20px 11px;\n    margin-bottom: 5px;\n    color: #55735A;\n    letter-spacing: 1px;\n    border-bottom: solid 1px #CAD0CC;\n}\n\n.dropdown-menu .divider {\n    margin: 5px 0;\n    background-color: #CAD0CC;\n}\n\n\n\n.navbar-breadcrumbs {\n    min-height: 28px;\n    margin: -9px 0 10px;\n    padding-top: 5px;\n    background: rgba(249, 249, 249,1);\n    background: -moz-linear-gradient(top, rgba(249, 249, 249,1) 0%, rgba(247,247,247,1) 100%);\n    background: -webkit-gradient(left top, left bottom, color-stop(0%, rgba(249, 249, 249,1)), color-stop(100%, rgba(247,247,247,1)));\n    background: -webkit-linear-gradient(top, rgba(249, 249, 249,1) 0%, rgba(247,247,247,1) 100%);\n    background: -o-linear-gradient(top, rgba(249, 249, 249,1) 0%, rgba(247,247,247,1) 100%);\n    background: -ms-linear-gradient(top, rgba(249, 249, 249,1) 0%, rgba(247,247,247,1) 100%);\n    background: linear-gradient(to bottom, rgb(249, 249, 249) 0%, rgba(247,247,247,1) 100%) filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#e6e4e5', endColorstr='#f7f7f7', GradientType=0 );\n    -webkit-box-shadow: 0px 0px 10px 0px rgba(169, 187, 176,1);\n    -moz-box-shadow: 0px 0px 10px 0px rgba(169, 187, 176,1);\n    box-shadow: 0 0 10px 0 rgb(165, 179, 170);\n}\n\n\n.navbar-nfse ul.nav li {\n    padding: 8px 2px;\n}\n\n.navbar-nfse .navbar-nav > li > a {\n    padding-top: 12px;\n    padding-bottom: 11px;\n    min-height: 46px;\n}\n\n    .navbar-nfse .navbar-nav > li > a .fa {\n        font-size: 18px !important;\n    }\n\n.navbar-nfse .input-group {\n    padding-left: 2px;\n}\n\n.navbar-nfse .navbar-collapse {\n    padding-right: 0;\n    padding-left: 0;\n}\n\n.navbar-nfse .navbar-form {\n    padding: 0;\n}\n\n.navbar-nav a img {\n    position: relative;\n}\n\n.navbar-brand img {\n    position: relative;\n    border-right: 1px solid #bbb;\n    padding-right: 10px;\n}\n\n.navbar-brand:after {\n    content: \"PORTAL CONTRIBUINTE\";\n    color: #709f77;\n    position: relative;\n    top: 14px;\n    display: inline-block;\n    font-size: 24px;\n    padding-left: 5px;\n    font-family: 'Roboto';\n    font-weight: 700;\n}\n\n.td-opcoes .dropdown-menu {\n    top: -85px;\n    right: 30px;\n    border-radius: 0;\n    padding: 0;\n}\n\n    .td-opcoes .dropdown-menu:before {\n        position: absolute;\n        top: 83px;\n        right: -10px;\n        display: inline-block;\n        border-top: 10px solid transparent;\n        border-left: 10px solid #ccc;\n        border-bottom: 10px solid transparent;\n        border-left-color: rgba(0, 0, 0, 0.2);\n        content: '';\n    }\n\n    .td-opcoes .dropdown-menu:after {\n        position: absolute;\n        top: 84px;\n        right: -9px;\n        display: inline-block;\n        border-bottom: 9px solid transparent;\n        border-left: 9px solid #ffffff;\n        border-top: 9px solid transparent;\n        content: '';\n    }\n\n    .td-opcoes .dropdown-menu a {\n        margin: 0;\n        color: #787993;\n        padding: 8px 15px;\n        border-bottom: solid 1px #ECECEC;\n    }\n\n        .td-opcoes .dropdown-menu a:hover {\n            background-color: #E5F1E7;\n            color: #709e77;\n        }\n\n        .td-opcoes .dropdown-menu a i, .td-opcoes .dropdown-menu a img {\n            margin-right: 5px;\n            color: #709e77;\n        }\n\n\n/*.perfil {\n    text-align: right;\n    padding-right: 15px;\n    font-size: 14px;\n}\n\n    .perfil > a {\n        padding: 23px 48px 21px 10px !important;\n        height: 86px;\n    }\n\n        .perfil > a > i {\n            position: absolute;\n            right: 11px;\n            top: 29px;\n            color: #344389;\n        }\n\n    .perfil .nome {\n        font-size: 14px;\n        display: block;\n        color: #223163;\n    }\n\n    .perfil .complemento {\n        font-size: 12px;\n        display: block;\n        color: #223163;\n    }\n\n    .perfil .dropdown-menu {\n        top: 99%;\n        right: 15px;\n        left: 0px;\n        background-color: #D7DCD9;\n        border-radius: 0;\n        border-width: 0;\n    }\n\n        .perfil .dropdown-menu i {\n            padding-right: 10px;\n            color: #709e77;\n        }\n\n        .perfil .dropdown-menu a {\n            color: #787933;\n            padding: 10px 20px;\n        }\n\n            .perfil .dropdown-menu a:hover {\n                color: #709E77;\n                background-color: #C9D4CD;\n            }\n\n        .perfil .dropdown-menu .divider {\n            background-color: #C1D0C7;\n        }*/\n\n\n.helpBox {\n    color: #AFBFCE;\n    margin-left: 5px;\n}\n\n    .helpBox:hover {\n        color: #709e77;\n        cursor: pointer;\n    }\n\n.blocked {\n    color: #929292 !important;\n    cursor: not-allowed;\n    border: solid 1px #e1e1e1;\n    background-color: #E1E1E1 !important;\n    border: solid 1px #e1e1e1 !important;\n}\n\n.form-control-div-disabled {\n    background-color: #E7E7E7;\n    box-shadow: none;\n    border: solid 1px #e1e1e1;\n    padding: 10px 16px;\n    font-size: 18px;\n    line-height: 1.3333333;\n    color: #555;\n}\n\n.form-control,\n.input-group-addon {\n    border-radius: 0px !important;\n}\n\n.input-group-addon {\n    background-color: #eee;\n    border: 1px solid #ccc;\n}\n\n\n\n\n.bd-callout {\n    background-color: #ECECEC;\n    padding: 10px;\n    margin-top: 12px;\n    margin-bottom: 12px;\n    border-width: 0;\n    border: solid 1px #DADADA;\n    border-left: 5px solid #CACACA;\n}\n\n    .bd-callout h4 {\n        margin: 0;\n        padding-bottom: 12px;\n        font-size: 16px;\n        color: #333;\n    }\n\n    .bd-callout ul {\n        list-style-type: disc;\n        padding-left: 20px;\n        padding-right: 10px;\n        text-align: justify;\n        margin-bottom: 0;\n    }\n\n        .bd-callout ul li {\n            margin-bottom: 10px;\n        }\n\n            .bd-callout ul li:last-child {\n                margin-bottom: 0;\n            }\n\n.bd-callout-warning {\n    border-color: #E8E6B2;\n    border-left-color: #DED633;\n    background-color: #FFFDD1;\n}\n\n    .bd-callout-warning h4 {\n        color: #9E9814;\n    }\n\n.bd-callout-info {\n    border-color: #DAE9F7;\n    border-left-color: #85B5E0;\n    background-color: #E8F4FF;\n}\n\n    .bd-callout-info h4 {\n        color: #2C72B3;\n    }\n\n    .bd-callout-info ul li {\n        color: #4C6A86;\n    }\n\n\n\n.alert {\n    border-radius: 0px !important;\n    padding-left: 45px;\n    padding-right: 45px;\n    position: relative;\n    text-align: justify;\n}\n\n    .alert span.icone {\n        width: 20px;\n        height: 20px;\n        position: absolute;\n        -webkit-transform: translateY(-50%);\n        -ms-transform: translateY(-50%);\n        -o-transform: translateY(-50%);\n        transform: translateY(-50%);\n        position: absolute;\n        top: 50%;\n        left: 13px;\n    }\n\n    .alert.alert-danger {\n        color: #920a0a;\n        background-color: #f6e7e7;\n        border-color: #c05a5a;\n    }\n\n        .alert.alert-danger .icone {\n            background: url('../img/icon_erro.png') no-repeat;\n        }\n\n    .alert.alert-warning {\n        color: #9a5b01;\n        background-color: #f5e8bf;\n        border-color: #ba760b;\n    }\n\n        .alert.alert-warning .icone {\n            background: url('../img/icon_alerta.png') no-repeat;\n        }\n\n    .alert.alert-success {\n        color: #054121;\n        background-color: #dde8df;\n        border-color: #709e77;\n    }\n\n        .alert.alert-success .icone {\n            background: url('../img/icon_sucesso.png') no-repeat;\n        }\n\n    .alert.alert-info {\n        color: #085373;\n        background-color: #d5e7f7;\n        border-color: #4e9dc6;\n    }\n\n        .alert.alert-info .icone {\n            background: url('../img/icon_info.png') no-repeat;\n        }\n\n    .alert ul {\n        padding: 0;\n        list-style: none;\n    }\n\n        .alert ul li {\n            padding: 3px 0 3px 10px;\n        }\n\n            .alert ul li.titulo {\n                padding-left: 0;\n            }\n\n    .alert .close {\n        position: absolute;\n        right: 10px;\n        top: 16px;\n        width: 28px;\n        height: 28px;\n        opacity: 0.3;\n    }\n\n        .alert .close:hover {\n            opacity: 1;\n        }\n\n        .alert .close:before, .alert .close:after {\n            position: absolute;\n            left: 15px;\n            content: ' ';\n            height: 20px;\n            width: 2px;\n            background-color: #374239;\n        }\n\n        .alert .close:before {\n            transform: rotate(45deg);\n        }\n\n        .alert .close:after {\n            transform: rotate(-45deg);\n        }\n\n.sem-registros {\n    color: #999;\n    background-color: #fff;\n    display: block;\n    padding: 40px;\n    text-align: center;\n    font-style: italic;\n    border: solid 1px #E6E6E6;\n    border-width: 1px 0;\n}\n\n.field-validation-error {\n    font-size: 12px;\n}\n\n.form-group.erro {\n    position: relative;\n}\n\n    .form-group.erro input,\n    .form-group.erro select,\n    .form-group.erro textarea,\n    .form-group.erro .chosen-single,\n    .form-group.erro .radiobutton .cr,\n    .form-group.erro .input-group-addon,\n    .form-group.erro .input-group-btn .btn {\n        border-color: #c05a5a !important;\n    }\n\n    .form-group.erro .text-danger {\n        color: #a41313;\n    }\n\n    .form-group.erro .form-control.monetario {\n        border-left-width: 0;\n    }\n\n    .form-group.erro .form-control.percentual {\n        border-right-width: 0;\n    }\n\n\n.input-group-btn .btn {\n    background-color: #E5F1E7;\n    border-left-width: 0;\n    color: #709E77;\n    border-color: #ccc;\n    border-left-width: 0;\n    border-radius: 0 !important;\n}\n\n    .input-group-btn .btn:hover {\n        background-color: #DBE8DD;\n        border-color: #ccc;\n    }\n\n    .input-group-btn .btn.btn-group-separado {\n        margin-left: 5px;\n        border-width: 1px;\n        padding: 0 14px;\n    }\n\n\n.input-group-btn > button[disabled],\n.input-group-btn > button[disabled]:hover,\n.input-group-btn > button[readonly],\n.input-group-btn > button[readonly]:hover {\n    background-color: #e7e7e7;\n    color: #B1B1B1;\n    border: solid 1px #e1e1e1;\n    border-left-width: 0;\n}\n\n.input-group-addon:first-child {\n    border-right: 0;\n}\n\n.input-group-addon:last-child {\n    border-left: 0;\n}\n\n.sem-borda-esquerda {\n    border-left-width: 0 !important;\n}\n\nsem-borda-direita {\n    border-right-width: 0 !important;\n}\n\n/*.input-validation-error {\n    border-color: #F34242 !important;\n}*/\n\n/*.text-danger {\n    color: #C11A17;\n}*/\n\ntextarea:focus,\nselect:focus,\ninput[type=\"text\"]:focus {\n    border-color: rgba(112, 158, 119, 0.8) !important;\n    box-shadow: 0 1px 1px rgba(0, 0, 0, 0.075) inset, 0 0 8px rgba(112, 158, 119, 0.6) !important;\n}\n\nselect option:hover {\n    background: rgba(0, 0, 0, 0.3);\n    color: #fff;\n}\n\nlabel {\n    font-size: 16px;\n    color: #444;\n    font-weight: normal;\n}\n\n    label .asterisco {\n        padding-left: 5px;\n        color: #c05a5a;\n    }\n\n.navbar-brand {\n    height: inherit;\n    padding: 20px 15px;\n    color: #C2E0FB !important;\n}\n\n    .navbar-brand:hover,\n    .navbar-brand:focus {\n        color: #C2E0FB;\n    }\n\n    .navbar-brand span.titulo {\n        color: #FFFFFF;\n        display: block;\n        font-size: 24px;\n        margin-bottom: 5px;\n    }\n\n    .navbar-brand span.home a {\n        color: #C2E0FB;\n        margin-right: 5px;\n    }\n\n        .navbar-brand span.home a:hover {\n            color: #5BC0DE;\n        }\n\n    .navbar-brand.simples {\n        display: none;\n    }\n\n    .navbar-brand.completa {\n        display: block;\n    }\n\n\n\n\n\n.radio-options {\n    display: block;\n    width: 100%;\n    padding-left: 0;\n    padding-top: 5px;\n    /*display: inline-block;\n    padding-left: 20px;*/\n}\n\n    .radio-options label {\n        font-size: 16px;\n    }\n\n    .radio-options .control-label {\n        margin-bottom: 10px;\n    }\n\n/*.form-inline .radio-options {\n    margin-top: 10px;\n    display: inline-block;\n    padding-left: 20px;\n    margin-bottom: 15px;\n}*/\n\n\n.popover {\n    border-radius: 0;\n    background-color: #FDFDE6;\n}\n\n    .popover > .arrow:after {\n        border-top-color: #FDFDE6 !important;\n    }\n\n    .popover .popover-content {\n        color: #444444;\n        font-size: 13px;\n        font-weight: 300;\n    }\n\n.form-control[disabled],\n.form-control[readonly],\nfieldset[disabled] .form-control {\n    background-color: #e7e7e7;\n    box-shadow: none;\n    border: solid 1px #e1e1e1;\n}\n\n.btn.disabled, .btn[disabled], fieldset[disabled] .btn {\n    filter: alpha(opacity=100);\n    opacity: 1;\n}\n\n.modal .modal-header {\n    background-color: #F1F1F1;\n    padding: 0 15px;\n    border-width: 0;\n    background: -moz-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n    background: -webkit-gradient(left top, left bottom, color-stop(0%, rgba(225,225,225,1)), color-stop(100%, rgba(247,247,247,1)));\n    background: -webkit-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n    background: -o-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n    background: -ms-linear-gradient(top, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n    background: linear-gradient(to bottom, rgba(225,225,225,1) 0%, rgba(247,247,247,1) 100%);\n    filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#e1e1e1', endColorstr='#f7f7f7', GradientType=0 );\n}\n\n    .modal .modal-header h4 {\n        padding: 15px 0;\n        color: #709e77;\n        font-size: 20px;\n        border-bottom: solid 2px #8bb091;\n        margin-bottom: 18px;\n        text-transform: uppercase;\n        font-weight: 400;\n    }\n\n    .modal .modal-header button {\n        width: 14px;\n        height: 14px;\n        position: absolute;\n        right: 15px;\n        top: 22px;\n        background: url('../img/fechar_on.png') no-repeat;\n    }\n\n        .modal .modal-header button:hover {\n            background: url('../img/fechar_off.png') no-repeat;\n        }\n\n.modal .modal-body {\n    max-height: 500px;\n    overflow: auto;\n}\n\n    .modal .modal-body > .bd-callout {\n        margin-top: 0;\n    }\n\n.modal .modal-footer {\n    /*text-align: center;*/\n    background-color: #f1f1f1;\n    border-width: 0;\n    background: -moz-linear-gradient(top, rgba(247,247,247,1) 0%, rgba(225,225,225,1) 100%);\n    background: -webkit-gradient(left top, left bottom, color-stop(0%, rgba(247,247,247,1)), color-stop(100%, rgba(225,225,225,1)));\n    background: -webkit-linear-gradient(top, rgba(247,247,247,1) 0%, rgba(225,225,225,1) 100%);\n    background: -o-linear-gradient(top, rgba(247,247,247,1) 0%, rgba(225,225,225,1) 100%);\n    background: -ms-linear-gradient(top, rgba(247,247,247,1) 0%, rgba(225,225,225,1) 100%);\n    background: linear-gradient(to bottom, rgba(247,247,247,1) 0%, rgba(225,225,225,1) 100%);\n    filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#e1e1e1', endColorstr='#f7f7f7', GradientType=0 );\n}\n\n.modal .modal-content {\n    border-radius: 0;\n}\n\n/*.modal .modal-footer .btn span {\n    padding: 0 5px 0 10px;\n    font-size: 16px;\n}*/\n\n\n\n#modalDeducao .modal-body {\n    overflow-y: scroll;\n}\n\n#modalSelecaoPessoa .modal-body {\n    overflow-y: scroll;\n}\n\n#modalSelecaoPessoa .table > tbody tr {\n    cursor: pointer;\n    height: 46px;\n}\n\n/* line 1, loading.css */\n.modalBgLoading {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    *width: 200%;\n    *margin: 0 0 0 -14%;\n    height: 100%;\n    background-color: rgba(0, 0, 0, 0.8);\n    z-index: 99999;\n}\n    /* line 12, loading.css */\n    .modalBgLoading .loading {\n        position: absolute;\n        z-index: 65557;\n        width: 50%;\n        height: 100px;\n        /*background-color: rgba(255, 255, 255, 0.7);*/\n        /*border-radius: 50px;*/\n        /*border: 2px solid #fff;*/\n        top: 20%;\n        left: 25%;\n        /*margin-left: -60px;\n                margin-top: -60px;*/\n    }\n\n    .modalBgLoading .texto {\n        color: #FFFFFF;\n        text-align: center;\n        margin-top: 20px;\n    }\n\n\n.icone-status {\n    font-size: 0px;\n}\n\n    .icone-status.passo {\n        color: #777c93;\n    }\n\n        .icone-status.passo span.emissao {\n            background: url(../img/passos-nfse-fechado-ico.svg) no-repeat center center;\n            height: 23px;\n            width: 23px;\n            display: inline-block;\n            filter: brightness(0.75);\n        }\n\n        .icone-status.passo span.pessoas {\n            background: url(../img/passos-pessoas-fechado-ico.svg) no-repeat center center;\n            height: 23px;\n            width: 23px;\n            display: inline-block;\n            filter: brightness(0.75);\n        }\n\n        .icone-status.passo span.tributacao {\n            background: url(../img/passos-valores-fechado-ico.svg) no-repeat center center;\n            height: 23px;\n            width: 23px;\n            display: inline-block;\n            filter: brightness(0.75);\n        }\n\n        .icone-status.passo span.servico {\n            background: url(../img/passos-servico-fechado-ico.svg) no-repeat center center;\n            height: 23px;\n            width: 23px;\n            display: inline-block;\n            filter: brightness(0.75);\n        }\n\n        .icone-status.passo span.substituicao {\n            background: url(../img/passos-subs-fechado-ico.svg) no-repeat center center;\n            height: 23px;\n            width: 23px;\n            display: inline-block;\n            filter: brightness(0.75);\n        }\n\n\n.tooltip {\n    /*text-transform: uppercase;*/\n    letter-spacing: 1px;\n    /*min-width: 110px;*/\n    font-size: 13px;\n    color: #fff;\n}\n\n    /*.tooltip .tooltip-inner {\n        border-radius: 0;\n        background-color: #ddebdf;\n        border: solid 1px #8db192;\n        opacity: 1;\n    }*/\n\n\n    /*----------------------------------------------------------------------------------*/\n\n    .tooltip.in {\n        opacity: 1;\n    }\n\n.tooltip-inner {\n    max-width: 400px;\n    padding: 3px 8px;\n    color: #fff; /*#444;*/\n    font-weight: 400;\n    font-size: 13px;\n    text-align: center;\n    background-color: #777c93; /* #ddebdf;*/\n    border-radius: 0px;\n    font-family: 'Roboto', sans-serif;\n    /*border-top: solid 1px #a6c3a9;\n  border-left: solid 1px #a6c3a9;\n  border-right: solid 1px #a6c3a9;\n  box-shadow: 1px 1px 25px #999; */ /* #8db192;*/\n}\n\n.tooltip-arrow {\n    position: absolute;\n    width: 0;\n    height: 0;\n    border: solid 0px transparent;\n}\n\n.tooltip.top {\n    padding: 5px 0;\n    margin-top: -3px;\n}\n\n    .tooltip.top .tooltip-arrow {\n        bottom: 0;\n        left: 50%;\n        margin-left: -5px;\n        border-top: solid 6px #777c93; /* #ddebdf;*/\n    }\n\n\n.tooltip.bottom {\n    padding: 5px 0;\n    margin-bottom: -3px;\n}\n\n    .tooltip.bottom .tooltip-arrow {\n        bottom: 0;\n        left: 50%;\n        margin-left: -5px;\n        border-bottom: solid 6px #777c93; /* #ddebdf;*/\n    }\n\n\n.tooltip.left {\n    padding: 5px 0;\n    margin-left: -3px;\n}\n\n    .tooltip.left .tooltip-arrow {\n        bottom: 0;\n        left: 50%;\n        margin-left: -5px;\n        border-left: solid 6px #777c93; /* #ddebdf;*/\n    }\n\n.tooltip.right {\n    padding: 5px 0;\n    margin-right: -3px;\n}\n\n    .tooltip.right .tooltip-arrow {\n        bottom: 0;\n        left: 50%;\n        margin-left: -5px;\n        border-right: solid 6px #777c93; /* #ddebdf;*/\n    }\n/*----------------------------------------------------------------------------------*/\n\n\n\n.linkBuscaAvancada {\n    position: absolute;\n    right: 0;\n    top: 9px;\n    font-size: 12px;\n}\n\n#pnlPesquisaAvancada {\n    background-color: #fff;\n    margin: 30px 0 5px;\n    display: none;\n    padding: 15px;\n}\n\n#pnlComandos {\n    margin: 0 0 10px;\n    padding: 0;\n}\n\n    #pnlComandos .acoes {\n        padding-left: 0;\n    }\n\n        #pnlComandos .acoes .btn {\n            border-width: 0;\n            vertical-align: top;\n        }\n\n.btn span {\n    padding: 0 5px 0 10px;\n    /*font-size: 16px;*/\n}\n\n#pnlComandos .pesquisa {\n    padding-right: 0;\n}\n\n\n\n.logo-box {\n    position: relative;\n    padding-left: 225px;\n    margin: 10px 0;\n    min-height: 192px;\n}\n\n.logo-img {\n    position: absolute;\n    left: 0;\n    padding: 5px;\n    background-color: #fff;\n    border: solid 1px #e1e1e1;\n}\n\n\n\n.dashboard-sem-registros {\n    color: #6F6F6F;\n    display: block;\n    padding: 5px 20px;\n    text-align: center;\n    font-style: italic;\n    border-width: 1px 0;\n}\n\n.dashboard-estatistica {\n    position: relative;\n    background-color: #fff;\n    padding: 10px;\n    min-height: 106px;\n    text-align: center;\n    border: 1px solid #e1e1e1;\n    border-width: 1px 0;\n}\n\n    .dashboard-estatistica .nome {\n        display: block;\n        font-size: 16px;\n        line-height: 18px;\n    }\n\n    .dashboard-estatistica .valor {\n        display: block;\n        color: #5BC0DE;\n        font-size: 26px;\n    }\n\n\n.dashboard-panel {\n    position: relative;\n    background-color: #fff;\n    padding: 15px;\n    margin-bottom: 20px;\n    min-height: 106px;\n    border: 1px solid #e1e1e1;\n    border-width: 1px 0;\n}\n\n    .dashboard-panel i {\n        position: absolute;\n        font-size: 40px;\n        top: 30px;\n        color: #ccc;\n        width: 50px;\n        text-align: center;\n    }\n\n    .dashboard-panel .info {\n        margin-left: 65px;\n    }\n\n        .dashboard-panel .info .nome {\n            display: block;\n            font-size: 18px;\n        }\n\n        .dashboard-panel .info .municipio {\n            display: block;\n            color: #666;\n            margin-bottom: 7px;\n        }\n\n        .dashboard-panel .info .valor {\n            display: block;\n            color: #666;\n            margin-bottom: 7px;\n        }\n\n        .dashboard-panel .info a {\n            color: #5BC0DE;\n            margin-right: 10px;\n            font-size: 12px;\n        }\n\n            .dashboard-panel .info a:hover {\n                text-decoration: none;\n            }\n\n\n\n.formulario {\n    background-color: #fff;\n    padding: 5px 15px;\n    border: solid 1px #e1e1e1;\n    border-width: 1px 0;\n}\n\n\n/*.form-panel {\n    position: relative;\n    border-radius: 0;\n    margin-top: 30px;\n}\n\n    .form-panel:first-child {\n        margin-top: 15px;\n    }\n\n    .form-panel .panel-heading {\n        position: absolute;\n        top: -10px;\n        padding: 2px 9px;\n        background-color: #fff !important;\n        border-width: 0px;\n        left: 12px;\n    }\n\n        .form-panel .panel-heading .panel-title {\n            color: #2A88D8;\n            text-transform: uppercase;\n            font-size: 14px;\n            font-weight: bold;\n        }\n\n    .form-panel .panel-body {\n        padding: 25px 15px 0;\n    }\n\n    .form-panel .form-panel {\n        margin-top: 15px;\n        margin-bottom: 3px;\n    }*/\n\n\n\n.panel-group .panel {\n    border-radius: 0;\n    border: 1px solid #e1e1e1;\n    border-width: 1px 0;\n    background-color: #F7F7F7;\n}\n\n.panel-default > .panel-heading {\n    padding: 0;\n}\n\n    .panel-default > .panel-heading a {\n        color: #333;\n        text-decoration: none;\n        font-size: 18px;\n        color: #709E77;\n    }\n\n        .panel-default > .panel-heading a:hover {\n            text-decoration: none;\n        }\n\n\n\n.panel-title {\n    font-size: 16px;\n    font-weight: normal;\n}\n\n    .panel-title a.btn-selecionar {\n        position: absolute;\n        top: 0;\n        right: 0;\n        color: #ccc;\n        padding: 14px 12px 10px;\n    }\n\n        .panel-title a.btn-selecionar:hover {\n            color: #344389 !important;\n            background-color: #eaeaea !important;\n        }\n\n.panel-heading {\n    position: relative;\n}\n\n    .panel-heading:hover .panel-title a.btn-selecionar {\n        color: #709E77;\n    }\n\n    .panel-heading .accordion-toggle {\n        display: block;\n        position: relative;\n        padding: 12px 10px 12px 32px;\n    }\n\n        .panel-heading .accordion-toggle:after {\n            font-family: 'Fontawesome';\n            content: \"\\f107\";\n            color: #709E77;\n            font-size: 24px;\n            position: absolute;\n            left: 9px;\n            top: 8px;\n            -webkit-transition: all 0.2s ease-out;\n            -moz-transition: all 0.2s ease-out;\n            -ms-transition: all 0.2s ease-out;\n            -o-transition: all 0.2s ease-out;\n            transition: all 0.2s ease-out;\n        }\n\n        .panel-heading .accordion-toggle.collapsed:after {\n            -webkit-transform: rotate(-90deg);\n            -moz-transform: rotate(-90deg);\n            -ms-transform: rotate(-90deg);\n            -o-transform: rotate(-90deg);\n            transform: rotate(-90deg);\n            -webkit-transition: all 0.2s ease-out;\n            -moz-transition: all 0.2s ease-out;\n            -ms-transition: all 0.2s ease-out;\n            -o-transition: all 0.2s ease-out;\n            transition: all 0.2s ease-out;\n        }\n\n.panel-body {\n    border-width: 0 !important;\n}\n\n    .panel-body p:last-child {\n        margin: 0;\n    }\n\n\n\n\n.table {\n    /*font-size: 14px;*/\n}\n\n    .table > thead {\n        /*font-size: 16px;*/\n    }\n\n        .table > thead > tr > th {\n            color: #709E77;\n            vertical-align: bottom;\n            border-bottom: 1px solid #709E77;\n            /*border-bottom: 1px solid #DADADA;*/\n            /*font-weight: normal;*/\n        }\n\n            .table > thead > tr > th a {\n                text-decoration: none;\n                color: #709e77;\n            }\n\n                .table > thead > tr > th a:hover {\n                    text-decoration: none;\n                    color: #709e77;\n                }\n\n            .table > thead > tr > th .sortIcon {\n                font-size: 16px;\n                color: #777C93;\n                padding-left: 5px;\n            }\n\n    .table > tbody > tr > td {\n        padding: 12px 8px 7px;\n        /* background-color: #f7f7f7; */\n        /* border-top-width: 0; */\n        /* border-bottom: 1px solid #DCDCDC; */\n        border-width: 0;\n        transition: all 0.2s ease-in-out;\n    }\n\n        .table > tbody > tr > td > span {\n            display: none;\n        }\n\n    .table .th-checkbox {\n        width: 25px;\n    }\n\n    .table .td-valor {\n        width: 120px;\n        text-align: right;\n    }\n\n    .table .td-center {\n        text-align: center;\n    }\n\n    .table .td-inscricao {\n        width: 210px;\n    }\n\n    .table .td-nif {\n        width: 280px;\n    }\n\n    .table .td-texto-grande {\n        position: relative;\n    }\n\n        .table .td-texto-grande div {\n            white-space: nowrap;\n            position: absolute;\n            width: 100%;\n            top: 13px;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n    .table .td-opcoes {\n        width: 40px;\n        font-size: 18px;\n        text-align: center;\n    }\n\n        .table .td-opcoes.deducao {\n            width: 70px;\n        }\n\n        .table .td-opcoes a {\n            opacity: .3;\n            color: #328F5C;\n            /*margin-left: 5px;*/\n        }\n\n            .table .td-opcoes a:hover {\n                opacity: 1;\n            }\n\n            .table .td-opcoes a i {\n                margin-left: 5px;\n            }\n\n    .table .td-data {\n        width: 120px;\n        text-align: center;\n    }\n\n    .table .td-datahora {\n        width: 160px;\n        text-align: center;\n    }\n\n    .table .td-codServ {\n        width: 140px;\n        text-align: center;\n    }\n\n    .table .td-tipoemissao {\n        width: 120px;\n        text-align: center;\n    }\n\n        .table .td-tipoemissao .fa {\n            cursor: pointer;\n        }\n\n\n    .table .td-situacao,\n    .table .td-impostos {\n        width: 110px;\n        text-align: center;\n    }\n\n        .table .td-situacao .fa,\n        .table .td-impostos .fa {\n            cursor: pointer;\n            font-size: 18px;\n        }\n\n            .table .td-situacao .fa:not(:first-child),\n            .table .td-impostos .fa:not(:first-child) {\n                padding-left: 8px;\n            }\n\n    .table > tbody > tr.selecionada > td {\n        background-color: #D4E2D6;\n    }\n\n    .table > tbody > tr.selecionada .td-opcoes a {\n        opacity: 1;\n    }\n\n    .table > tbody > tr:hover > td {\n        /*background-color: #ddebdf;*/\n        background-color: #DFECE1;\n    }\n\n    .table > tbody > tr:hover .td-opcoes a {\n        opacity: 0.8;\n    }\n\n    .table > tbody > tr.totalizador {\n        border-top: 1px solid #DADADA;\n        font-weight: bold;\n        background-color: #F7F7F7 !important;\n    }\n\n        .table > tbody > tr.totalizador .total {\n            font-weight: normal;\n            display: block;\n        }\n\n        .table > tbody > tr.totalizador:hover > td {\n            background-color: #F7F7F7 !important;\n        }\n\n    .table > tbody > tr.selecionado > td {\n        background-color: #CDE4D1;\n    }\n\n        .table > tbody > tr.selecionado > td.td-opcoes a {\n            opacity: 1 !important;\n        }\n\n.table-striped > tbody > tr {\n    background-color: #fff;\n}\n\n    .table-striped > tbody > tr:nth-of-type(odd) {\n        background-color: #F3F3F3;\n    }\n\n.table-striped img {\n    vertical-align: sub;\n    margin-right: 2px;\n}\n\n.table#tabelaDeducoes {\n    margin-top: 15px;\n}\n\n.table.tabela-favoritos tr {\n    cursor: pointer;\n}\n\n\n/* DEFINIÇÃO DO MENU SUSPENSO DAS LINHAS DOS GRIDS */\n.menu-suspenso-tabela .popover {\n    background-color: #FFF;\n    padding: 0;\n}\n\n    .menu-suspenso-tabela .popover > .arrow:after {\n        border-top-color: transparent !important;\n    }\n\n    .menu-suspenso-tabela .popover > .popover-content {\n        padding: 0;\n    }\n\n        .menu-suspenso-tabela .popover > .popover-content > a {\n            border-radius: 0;\n            border-width: 0;\n            padding: 10px 30px 10px 7px;\n            font-size: 14px;\n        }\n\n            .menu-suspenso-tabela .popover > .popover-content > a i {\n                padding-right: 10px;\n                font-size: 18px;\n                color: #97A29C;\n            }\n\n            .menu-suspenso-tabela .popover > .popover-content > a:hover i {\n                color: #344389;\n            }\n\n            .menu-suspenso-tabela .popover > .popover-content > a img {\n                margin: 0 7px 0 5px;\n                filter: saturate(0);\n                width: 18px;\n                vertical-align: middle;\n            }\n\n            .menu-suspenso-tabela .popover > .popover-content > a:hover img {\n                filter: saturate(1);\n            }\n\n\n\n.paginacao {\n    margin-bottom: 20px;\n}\n\n    .paginacao .indice {\n        text-align: left;\n    }\n\n    .paginacao .descricao {\n        text-align: right;\n        padding-top: 8px;\n        color: #444;\n        font-size: 14px;\n    }\n\n    .paginacao .pagination {\n        margin: 0;\n        border-radius: 0;\n        font-size: 14px;\n    }\n\n        .paginacao .pagination > li > a,\n        .paginacao .pagination > li > span {\n            border-width: 0;\n            color: #444444;\n        }\n\n            .paginacao .pagination > li > a:hover,\n            .paginacao .pagination > li > span:hover,\n            .paginacao .pagination > li > a:focus,\n            .paginacao .pagination > li > span:focus {\n                z-index: 2;\n                color: #709e77;\n                background-color: #f1f1f1;\n            }\n\n        .paginacao .pagination > .active > a,\n        .paginacao .pagination > .active > span,\n        .paginacao .pagination > .active > a:hover,\n        .paginacao .pagination > .active > span:hover,\n        .paginacao .pagination > .active > a:focus,\n        .paginacao .pagination > .active > span:focus {\n            z-index: 3;\n            color: #333;\n            cursor: default;\n            background-color: #ddebdf;\n        }\n\n\n\n\n/* ESTILO DOS CHECKBOXES */\n.table .checkbox {\n    margin-bottom: 0;\n}\n\n.checkbox {\n    margin: 0;\n    min-height: 15px;\n    margin-bottom: 15px;\n}\n\n    .checkbox label {\n        padding-left: 0;\n        min-height: 15px;\n        position: relative;\n    }\n\n        .checkbox label:after {\n            content: '';\n            display: table;\n            clear: both;\n        }\n\n    .checkbox .cr {\n        position: absolute;\n        /* display: inline-block; */\n        border: 1px solid #a9a9a9;\n        background-color: #fff;\n        top: 2px;\n        width: 15px;\n        height: 15px;\n        /* float: left; */\n        /* margin-right: .5em; */\n    }\n\n        .checkbox .cr .cr-icon {\n            position: absolute;\n            font-size: 13px;\n            line-height: 0;\n            top: 7px;\n            /* left: 0px; */\n        }\n\n    .checkbox .cr-text {\n        /*padding-left: 22px;*/\n        padding-left: 28px;\n        display: inline-block;\n    }\n\n    .checkbox .cr.paddingright {\n        margin-right: 8px;\n    }\n\n    .checkbox label input[type=\"checkbox\"] {\n        display: none;\n    }\n\n        .checkbox label input[type=\"checkbox\"] + .cr > .cr-icon {\n            transform: scale(3) rotateZ(-20deg);\n            opacity: 0;\n            transition: all .3s ease-in;\n        }\n\n        .checkbox label input[type=\"checkbox\"]:checked + .cr > .cr-icon {\n            transform: scale(1) rotateZ(0deg);\n            opacity: 1;\n            color: #709E77;\n        }\n\n        .checkbox label input[type=\"checkbox\"]:disabled + .cr {\n            opacity: .5;\n        }\n\n\n\n/* ESTILO DOS RADIOBUTTONS */\n.radiobutton {\n    margin: 0;\n    min-height: 15px;\n    margin-bottom: 5px;\n}\n\n    .radiobutton.inline {\n        /*display: inline;*/\n    }\n\n    .radiobutton label {\n        padding-left: 22px;\n        min-height: 15px;\n        min-width: 90px;\n        margin-right: 20px;\n        position: relative;\n        font-weight: normal;\n    }\n\n        .radiobutton label:after {\n            content: '';\n            display: table;\n            clear: both;\n        }\n\n        .radiobutton label:hover {\n            cursor: pointer;\n        }\n\n    .radiobutton .cr {\n        position: absolute;\n        border: 1px solid #a9a9a9;\n        background-color: #fff;\n        cursor: pointer;\n        top: 3px;\n        left: 0;\n        width: 16px;\n        height: 16px;\n        border-radius: 8px;\n    }\n\n        .radiobutton .cr .cr-icon {\n            position: absolute;\n            background-color: #709E77;\n            width: 8px;\n            height: 8px;\n            border-radius: 4px;\n            top: 3px;\n            left: 3px;\n        }\n\n    .radiobutton .cr-text {\n        padding-left: 22px;\n    }\n\n    .radiobutton .cr.paddingright {\n        margin-right: 8px;\n    }\n\n    .radiobutton label input[type=\"radio\"] {\n        display: none;\n    }\n\n        .radiobutton label input[type=\"radio\"] + .cr > .cr-icon {\n            transform: scale(3) rotateZ(-20deg);\n            opacity: 0;\n            transition: all .3s ease-in;\n        }\n\n        .radiobutton label input[type=\"radio\"]:checked + .cr > .cr-icon {\n            transform: scale(1) rotateZ(0deg);\n            opacity: 1;\n            color: #333;\n        }\n\n        .radiobutton label input[type=\"radio\"]:disabled + .cr,\n        .radiobutton label input[type=\"radio\"][readonly] + .cr {\n            opacity: .5;\n        }\n\n\n\n\n.btn {\n    letter-spacing: 1px;\n    transition: all 0.2s ease-in-out;\n    min-height: 43px;\n}\n\n.btn-descricao {\n    background: transparent url(../img/btn-editar2.svg) no-repeat center center;\n    width: 20px;\n    height: 20px;\n    padding: 12px;\n}\n\n.btn-primary {\n    color: #fff !important;\n    background-color: #344389;\n    border-color: #344389;\n}\n\n    .btn-primary:focus,\n    .btn-primary.focus,\n    .navbar-nav > li > a.btn-primary:focus {\n        color: #fff;\n        background-color: #1d2c71;\n        border-color: #1d2c71;\n    }\n\n    .btn-primary:hover,\n    .navbar-nav > li > a.btn-primary:hover {\n        color: #fff;\n        background-color: #1d2c71;\n        border-color: #1d2c71;\n    }\n\n    .btn-primary:active,\n    .btn-primary.active,\n    .open > .dropdown-toggle.btn-primary {\n        color: #fff;\n        background-color: #1d2c71;\n        border-color: #1d2c71;\n    }\n\n        .btn-primary:active:hover,\n        .btn-primary.active:hover,\n        .open > .dropdown-toggle.btn-primary:hover,\n        .btn-primary:active:focus,\n        .btn-primary.active:focus,\n        .open > .dropdown-toggle.btn-primary:focus,\n        .btn-primary:active.focus,\n        .btn-primary.active.focus,\n        .open > .dropdown-toggle.btn-primary.focus {\n            color: #fff;\n            background-color: #1d2c71;\n            border-color: #1d2c71;\n        }\n\n    .btn-primary:active,\n    .btn-primary.active,\n    .open > .dropdown-toggle.btn-primary {\n        background-image: none;\n    }\n\n    .btn-primary.disabled,\n    .btn-primary[disabled],\n    .btn-primary.disabled:hover,\n    .btn-primary[disabled]:hover,\n    fieldset[disabled] .btn-primary:hover,\n    .btn-primary.disabled:focus,\n    .btn-primary[disabled]:focus,\n    fieldset[disabled] .btn-primary:focus,\n    .btn-primary.disabled.focus,\n    .btn-primary[disabled].focus,\n    fieldset[disabled] .btn-primary.focus {\n        background-color: #ccc;\n        border-color: #ccc;\n    }\n\n    .btn-primary .badge {\n        color: #337ab7;\n        background-color: #fff;\n    }\n\n\n.btn-info {\n    color: #fff !important;\n    background-color: #777c93;\n    bord