            "mimeType": "text/css",
            "compression": 7658,
            "text": ".jdash {\n    position: relative;\n}\n\n    /*.coluna {\n    float: left;\n    min-height: 1px;\n}*/\n\n    .jdash .sector {\n        margin: 15px 0;\n        background: rgba(204,204,204,0.1);\n        border: 1px dashed #bbb;\n        display: none;\n    }\n\n    .jdash .widget {\n        position: relative;\n        display: none;\n        /*border: 1px solid #bbb;*/\n        margin: 15px 0;\n        z-index: 5;\n        background-color: #f7f7f7;\n        border-top: solid 1px #9DB3A1;\n        border-bottom: 1px solid #e1e1e1;\n    }\n\n        .jdash .widget.fechado {\n            /*-webkit-border-radius: 3px;\n        -moz-border-radius: 3px;\n        border-radius: 3px;*/\n        }\n\n        .jdash .widget.movendo {\n            opacity: .65;\n            z-index: 10;\n        }\n\n    .jdash .cabecalho {\n        cursor: move;\n        margin: 0;\n        font-size: 20px;\n        color: #709E77;\n        padding: 10px;\n        position: relative;\n        font-weight: 400;\n        border-bottom: 1px solid #ECECEC;\n        background: #E4E4E4;\n        background: -moz-linear-gradient(top, #E4E4E4 0%, #f7f7f7 100%);\n        background: -webkit-linear-gradient(top, #E4E4E4 0%,#f7f7f7 100%);\n        background: linear-gradient(to bottom, #E4E4E4 0%,#f7f7f7 100%);\n        filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#E4E4E4', endColorstr='#f7f7f7',GradientType=0 );\n    }\n\n    .jdash .cabecalho img {\n        vertical-align: text-top;\n        padding-right: 10px;\n        padding-left: 5px;\n        height: 25px;\n    }\n\n    .jdash .widget.movendo,\n    .jdash .widget.movendo .jdash .cabecalho {\n        cursor: move;\n        cursor: -webkit-grabbing;\n        cursor: -moz-grabbing;\n        cursor: grabbing;\n    }\n\n    /*.jdash .cabecalho:hover {\n    color: #000;\n}*/\n\n    .jdash .cabecalho-inner {\n        /*background: url(images/grain.png);\n    padding: 0 12px;*/\n    }\n\n    .jdash .widget.fechado .jdash .cabecalho {\n        border-bottom: 0;\n        -webkit-border-radius: 2px;\n        -moz-border-radius: 2px;\n        border-radius: 2px;\n    }\n\n.jdash-collapse {\n    position: absolute;\n    right: 5px;\n    top: 9px;\n    display: none;\n    height: 30px;\n    width: 30px;\n    background: url(images/arrows.png) no-repeat 11px 13px;\n    cursor: pointer;\n}\n\n    .jdash-collapse:hover {\n        background-position: 11px -12px;\n    }\n\n.jdash .widget.fechado .jdash-collapse {\n    background-position: -10px 12px;\n}\n\n    .jdash .widget.fechado .jdash-collapse:hover {\n        background-position: -10px -13px;\n    }\n\n.jdash .widget:hover .jdash-collapse {\n    display: block;\n}\n\n.jdash-toolbar {\n    padding-bottom: 8px;\n}\n\n.jdash .widget:hover .jdash-toolbar {\n    display: block;\n}\n\n.jdash .widget .jdash .cabecalho .jdash-toolbar button::-moz-focus-inner {\n    border: 0;\n    padding: 0;\n}\n\n.jdash .widget .jdash .cabecalho .jdash-toolbar button {\n    border: 1px solid #888;\n    padding: 4px 10px;\n    text-shadow: 0 1px 0 #fff;\n    font-size: 10px;\n    color: #333;\n    cursor: default;\n    margin: 0 2px;\n    background: #ddd;\n    background: -webkit-gradient(linear,0 0,0 100%,from(#fff),to(#ddd));\n    background: -webkit-linear-gradient(top,#fff,#ddd);\n    background: -moz-linear-gradient(top,#fff,#ddd);\n    background: -ms-linear-gradient(top,#fff,#ddd);\n    background: -o-linear-gradient(top,#fff,#ddd);\n    background: linear-gradient(top,#fff,#ddd);\n    filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#fff',endColorstr='#dddddd');\n    -ms-filter: \"progid:DXImageTransform.Microsoft.gradient(startColorstr='#fff', endColorstr='#dddddd')\";\n    -webkit-box-shadow: 0 1px 0 0 #f6f6f6;\n    -moz-box-shadow: 0 1px 0 0 #f6f6f6;\n    box-shadow: 0 1px 0 0 #f6f6f6;\n    -webkit-border-radius: 3px;\n    -moz-border-radius: 3px;\n    border-radius: 3px;\n}\n\n    .jdash .widget .jdash .cabecalho .jdash-toolbar button.left {\n        margin-right: 0;\n        -webkit-border-radius: 3px 0 0 3px;\n        -moz-border-radius: 3px 0 0 3px;\n        border-radius: 3px 0 0 3px;\n    }\n\n    .jdash .widget .jdash .cabecalho .jdash-toolbar button.center {\n        margin: 0;\n        border-left: 0;\n        -webkit-border-radius: 0;\n        -moz-border-radius: 0;\n        border-radius: 0;\n    }\n\n    .jdash .widget .jdash .cabecalho .jdash-toolbar button.right {\n        margin-left: 0;\n        border-left: 0;\n        -webkit-border-radius: 0 3px 3px 0;\n        -moz-border-radius: 0 3px 3px 0;\n        border-radius: 0 3px 3px 0;\n    }\n\n    .jdash .widget .jdash .cabecalho .jdash-toolbar button:active {\n        text-shadow: 0 1px 0 #ccc;\n        border-color: #555;\n        background: #999;\n        background: -webkit-gradient(linear,0 0,0 100%,from(#ccc),to(#999));\n        background: -webkit-linear-gradient(top,#ccc,#999);\n        background: -moz-linear-gradient(top,#ccc,#999);\n        background: -ms-linear-gradient(top,#ccc,#999);\n        background: -o-linear-gradient(top,#ccc,#999);\n        background: linear-gradient(top,#ccc,#999);\n        filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#ccc',endColorstr='#999999');\n        -ms-filter: \"progid:DXImageTransform.Microsoft.gradient(startColorstr='#ccc', endColorstr='#999999')\";\n        -webkit-box-shadow: inset 0 0 5px 0 #333,0 1px 0 0 #f6f6f6;\n        -moz-box-shadow: inset 0 0 5px 0 #333,0 1px 0 0 #f6f6f6;\n        box-shadow: inset 0 0 5px 0 #333,0 1px 0 0 #f6f6f6;\n    }\n\n.jdash-toolbar.compact {\n    position: absolute;\n    display: none;\n    right: 30px;\n    top: -1px;\n}\n\n.jdash .widget .jdash .cabecalho .jdash-toolbar.compact button {\n    padding: 3px 10px;\n}\n\n.jdash .widget .jdash .cabecalho .jdash-toolbar.compact a.jdash-icon {\n    position: relative;\n    top: 3px;\n    display: block;\n    float: left;\n    width: 12px;\n    height: 12px;\n    padding: 7px;\n    opacity: .3;\n    -ms-filter: \"alpha(opacity=30)\";\n    filter: alpha(opacity=30);\n}\n\n    .jdash .widget .jdash .cabecalho .jdash-toolbar.compact a.jdash-icon:hover {\n        opacity: 1;\n        -ms-filter: \"alpha(opacity=100)\";\n        filter: alpha(opacity=100);\n    }\n\n    .jdash .widget .jdash .cabecalho .jdash-toolbar.compact a.jdash-icon img {\n        position: absolute;\n        left: 50%;\n        top: 50%;\n        margin-left: -6px;\n        margin-top: -6px;\n    }\n\n/*.jdash-info {\n    position: relative;\n    background: #f6f6f6 url(images/info.png) no-repeat 10px 11px;\n    border-bottom: 1px solid #e0e0e0;\n    padding: 9px 10px 8px 10px;\n    padding-left: 32px;\n    margin: -16px;\n    margin-bottom: 15px;\n    font-weight: normal;\n    color: #888;\n    font: italic 11px/18px \"Lucida Grande\",Verdana,Arial,sans-serif;\n}\n\n.jdash-info-arrow_fill, .jdash-info-arrow_stroke {\n    position: absolute;\n    left: 13px;\n    bottom: 100%;\n    width: 0;\n    height: 0;\n    border: 3px solid transparent;\n    border-bottom-color: #f4f4f4;\n    z-index: 2;\n}\n\n.jdash-info-arrow_stroke {\n    margin-bottom: 1px;\n    border-bottom-color: #ccc;\n    z-index: 1;\n}*/\n\n.jdash-body {\n    /*color: #666;*/\n    padding: 15px;\n    /*border: 1px solid #fff;\n    background: #fafafa;\n    background: -webkit-gradient(linear,0 0,0 100%,color-stop(0.8,#fcfcfc),color-stop(1,#fafafa));\n    background: -webkit-linear-gradient(top,#fcfcfc 80%,#fafafa);\n    background: -moz-linear-gradient(top,#fcfcfc 80%,#fafafa);\n    background: -ms-linear-gradient(top,#fcfcfc 80%,#fafafa);\n    background: -o-linear-gradient(top,#fcfcfc 80%,#fafafa);\n    background: linear-gradient(top,#fcfcfc 80%,#fafafa);\n    -webkit-border-radius: 0 0 2px 2px;\n    -moz-border-radius: 0 0 2px 2px;\n    border-radius: 0 0 2px 2px;*/\n}\n\n    .jdash-body.table {\n        padding: 7px;\n        margin: 0;\n    }\n\n        .jdash-body.table table {\n            margin: 0;\n            background-color: transparent;\n        }\n\n        .jdash-body.table .table > thead > tr > th {\n            color: #709E77;\n            font-weight: normal;\n            vertical-align: bottom;\n            border-bottom: 1px solid #ECECEC;\n        }\n\n/*.jdash .cabecalho .subtitle {\n    display: inline-block;\n    margin-left: 8px;\n    border-left: 1px solid rgba(0,0,0,.15);\n    padding-left: 8px;\n    font: 11px \"Lucida Grande\",Verdana,Arial,sans-serif;\n    color: #888;\n    overflow: hidden;\n    -webkit-box-shadow: inset 1px 0 0 rgba(255,255,255,.5);\n    -moz-box-shadow: inset 1px 0 0 rgba(255,255,255,.5);\n    box-shadow: inset 1px 0 0 rgba(255,255,255,.5);\n}\n\n.jdash .cabecalho:hover .subtitle {\n    color: #666;\n}*/\n\n.jdash-badge {\n    position: absolute;\n    top: -9px;\n    left: -7px;\n    padding: 0 4px;\n    height: 14px;\n    background: #d00;\n    font: bold 10px/14px \"Lucida Grande\",Verdana,Arial,sans-serif;\n    color: #fff;\n    z-index: 10;\n    border: 1px solid #900;\n    -webkit-border-radius: 25px;\n    -moz-border-radius: 25px;\n    border-radius: 25px;\n    -webkit-box-shadow: 0 1px 1px rgba(0,0,0,.2);\n    -moz-box-shadow: 0 1px 1px rgba(0,0,0,.2);\n    box-shadow: 0 1px 1px rgba(0,0,0,.2);\n}\n\n.clear {\n    clear: both;\n}\n\n\n\n\n\n\n.jdash .widget ul.leaders span:first-child {\n    background: #f7f7f7;\n}\n\n.jdash .widget ul.leaders span + span {\n    background: #f7f7f7;\n}\n\n.jdash .widget a.btnAcesso {\n    background-color: #ECECEC;\n    border: solid 1px #ECECEC;\n    padding: 15px 0;\n    text-align: center;\n    display: inline-block;\n    margin-bottom: 15px;\n    font-size: 32px;\n    color: #709E77;\n    width: 70px;\n}\n\n    .jdash .widget a.btnAcesso:hover {\n        background-color: #e7e7e7;\n        color: #709E77;\n    }\n\n    .jdash .widget a.btnAcesso.adicionar {\n        background-color: transparent;\n        color: #ccc;\n        border: dashed 1px #ccc;\n    }\n\n        .jdash .widget a.btnAcesso.adicionar:hover {\n            background-color: #f1f1f1;\n            color: #aaa;\n        }\n"
