          "cookies": [],
          "content": {
            "size": 22521,
            "mimeType": "text/html",
            "compression": 0,
            "text": "\r\n\r\n\r\n<!DOCTYPE html>\r\n\r\n<html>\r\n<head>\r\n    <meta name=\"viewport\" content=\"width=device-width\" />\r\n    <title>NFS-e | Portal Contribuinte</title>\r\n    <link href=\"https://fonts.googleapis.com/css?family=Roboto:300,400,500,700\" rel=\"stylesheet\">\r\n    <link href=\"/EmissorNacional/Content/Base?v=PNNgqFMeiX_JCCYDv-3Z3MCHsfnKA_V8oEHE8c3GJic1\" rel=\"stylesheet\"/>\r\n\r\n    \r\n    <link href=\"/EmissorNacional/Content/dashboard.css\" rel=\"stylesheet\" />\r\n\r\n    <script type=\"text/javascript\">\r\n        window.UrlBase = \"https://www.nfse.gov.br/emissornacional/\";\r\n        window.UrlRest = \"https://restnfseprod.srv.cd.serpro\";\r\n        window.sessionStorage.setItem(\"accessToken\", 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..NbxmMztIxsS5RyrY2k8NRGtMveQPH4EsnIHJemOEOSQ');\r\n    </script>\r\n    <script src=\"/EmissorNacional/Scripts/Base?v=9aYlZCGNwOnQ9M-uWKF6qWROrguA9sBYeGWayB9cXLg1\"></script>\r\n\r\n    \r\n    <script src=\"/EmissorNacional/Scripts/dashboard.js\"></script>\r\n    <script>\r\n        $(document).ready(function () {\r\n            // Inicializa o dashboard\r\n            $('#dashboard').jDashboard();            \r\n            // Evento click do botão adicionar acesso\r\n            $('#btnAdicionarAcesso').on('click', function () {\r\n                ExibirAlerta('Funcionalidade indisponível');\r\n            });\r\n        });\r\n    </script>\r\n\r\n</head>\r\n<body>\r\n    <nav class=\"navbar navbar-default navbar-static-top\">\r\n        <div class=\"container\">\r\n            <div class=\"navbar-header\">\r\n                <button type=\"button\" class=\"navbar-toggle collapsed\" data-toggle=\"collapse\" data-target=\"#navbar\" aria-expanded=\"false\" aria-controls=\"navbar\">\r\n                    <span class=\"sr-only\">Toggle navigation</span>\r\n                    <span class=\"icon-bar\"></span>\r\n                    <span class=\"icon-bar\"></span>\r\n                    <span class=\"icon-bar\"></span>\r\n                </button>\r\n                <div class=\"navbar-brand completa\">\r\n                    <a href=\"/EmissorNacional/\"><img src=\"/EmissorNacional/img/logo-nfse-assinatura-horizontal.svg\" /></a>\r\n                </div>\r\n                <div class=\"navbar-brand simples\">\r\n                    <a href=\"/EmissorNacional/\"><img src=\"/EmissorNacional/img/logo-header-simples.svg\" /></a>\r\n                </div>\r\n            </div>\r\n            <div id=\"navbar\" class=\"navbar-collapse collapse\">\r\n                <ul class=\"nav navbar-nav navbar-right\">\r\n                    <li>\r\n                        <a href=\"/EmissorNacional/\" data-toggle=\"tooltip\" data-placement=\"bottom\"\r\n                           title=\"Principal\"><div><img src=\"/EmissorNacional/img/menu-home-35.svg\" /></div><span class=\"nome-mobile\">Página Principal</span></a>\r\n                    </li>\r\n                    \r\n                    <li class=\"dropdown\">\r\n                        <a href=\"#\" class=\"dropdown-toggle\" data-toggle=\"dropdown\"\r\n                           role=\"button\" aria-haspopup=\"true\" aria-expanded=\"false\" data-hover=\"dropdown\">\r\n                            <div><img src=\"/EmissorNacional/img/menu-nova-35.svg\" /><span class=\"caret\"></span></div><span class=\"nome-mobile\">Nova NFS-e</span>\r\n                        </a>\r\n                        <ul class=\"dropdown-menu main-menu\" style=\"right: -5px; margin-top: 5px;\">\r\n                            <li class=\"dropdown-header titulo-menu\">Tipos de emissão:</li>\r\n                            <li>\r\n                                <a href=\"/EmissorNacional/DPS/Pessoas\">Emissão completa</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"/EmissorNacional/DPS/Simplificada\">Emissão simplificada</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"/EmissorNacional/ByPass/Pessoas\">Emissão por decisão administrativa/judicial</a>\r\n                            </li>\r\n                        </ul>\r\n                    </li>\r\n                    <li>\r\n                        <a href=\"/EmissorNacional/Notas/Emitidas\" data-toggle=\"tooltip\" data-placement=\"bottom\"\r\n                           title=\"NFS-e Emitidas\"><div><img src=\"/EmissorNacional/img/menu-emitidas-35.svg\" style=\"top: -10px;\" /></div><span class=\"nome-mobile\">NFS-e Emitidas</span></a>\r\n                    </li>\r\n                    <li>\r\n                        <a href=\"/EmissorNacional/Notas/Recebidas\" data-toggle=\"tooltip\" data-placement=\"bottom\"\r\n                           title=\"NFS-e Recebidas\"><div><img src=\"/EmissorNacional/img/menu-recebidas-35.svg\" /></div><span class=\"nome-mobile\">NFS-e Recebidas</span></a>\r\n                    </li>\r\n                    <li>\r\n                        <a href=\"/EmissorNacional/Notas/Rascunhos\" data-toggle=\"tooltip\" data-placement=\"bottom\"\r\n                           title=\"Rascunhos\"><div><img src=\"/EmissorNacional/img/menu-rascunhos-35.svg\" /></div><span class=\"nome-mobile\">Rascunhos</span></a>\r\n                    </li>\r\n\r\n                    <!-- MAN desabilitado em Produção Restrita\r\n                    <li class=\"dropdown\">\r\n                        <a href=\"#\" class=\"dropdown-toggle\" data-toggle=\"dropdown\"\r\n                           role=\"button\" aria-haspopup=\"true\" aria-expanded=\"false\" data-hover=\"dropdown\">\r\n                            <div><img src=\"~/img/menu-apuracao-35.svg\" /><span class=\"caret\"></span></div><span class=\"nome-mobile\">Apuração Nacional</span>\r\n                        </a>\r\n                        <ul class=\"dropdown-menu main-menu\" style=\"right: -5px; margin-top: 5px;\">\r\n                            <li class=\"dropdown-header titulo-menu\">Apuração Nacional:</li>\r\n                            <li>\r\n                                <a href=\"\">Pré-Apuração</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"\">Apuração</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"\">Arrecadação</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"\">Créditos/Débitos</a>\r\n                            </li>\r\n                        </ul>\r\n                    </li>\r\n                    -->\r\n\r\n                    <li>\r\n                        <a href=\"/EmissorNacional/Perfil/Configuracao\" data-toggle=\"tooltip\" data-placement=\"bottom\"\r\n                           title=\"Configurações\"><div><img src=\"/EmissorNacional/img/menu-config-35.svg\" /></div><span class=\"nome-mobile\">Configurações</span></a>\r\n                    </li>\r\n                    <li>\r\n                        <a href=\"/EmissorNacional/Perfil/ServicosFavoritos\" data-toggle=\"tooltip\" data-placement=\"bottom\"\r\n                           title=\"Serviços Favoritos\"><div><img src=\"/EmissorNacional/img/menu-favoritos-35.svg\" style=\"top: -2px;\" /></div><span class=\"nome-mobile\">Serviços Favoritos</span></a>\r\n                    </li>\r\n                    <li class=\"divisor\"></li>\r\n                    <li class=\"dropdown perfil\">\r\n                        <a href=\"#\" class=\"dropdown-toggle\" data-toggle=\"dropdown\"\r\n                           role=\"button\" aria-haspopup=\"true\" aria-expanded=\"false\" data-hover=\"dropdown\">\r\n                            <div><img style=\"top: 2px\" src=\"/EmissorNacional/img/menu-user-35.svg\" /><span class=\"caret\"></span></div>\r\n                        </a>\r\n                        <ul class=\"dropdown